# Copy to credentials.env and fill in. Do not commit credentials.env.
USERNAME=your_email@example.com
PASSWORD=your_password

# Run browser without a visible window (true/false)
HEADLESS=false

# ── Scouting budgets (0-20, in $M) ──
# Used to discount projections for under-scouted player types.
# Whichever is higher gets no penalty; the other is penalized relative to it.
SCOUTING_COLLEGE=0
SCOUTING_HIGH_SCHOOL=10

# ── Scouting trust formula ──
# trust = MIN_TRUST + (1 - MIN_TRUST) * (budget / 20) ^ CURVE
# The max budget in HBD is always $20M.
# Then the lower category is normalized relative to the higher one (higher always = 1.0).
# MIN_TRUST: floor multiplier at $0 scouting (0.10 = 90% discount)
# CURVE: exponent controlling how fast trust ramps up (lower = steeper early gain)
SCOUTING_MIN_TRUST=0.10
SCOUTING_CURVE=0.17

# ── Signability penalties (multipliers 0.0–1.0) ──
# Each value multiplies the player's adjusted score on the Master List.
# 1.0 = no penalty, 0.0 = exclude from draft consideration.
#
# SIGN_WILL_SIGN: "will sign for slot" / "looking to sign"
# SIGN_FIRST_ROUND: penalty if overall < threshold; no penalty if above
# SIGN_FIRST_ROUND_THRESHOLD: overall rating where first-round concern disappears
# SIGN_FIRST_FIVE: penalty if overall < threshold; no penalty if above
# SIGN_FIRST_FIVE_THRESHOLD: overall rating where first-five concern disappears
# SIGN_MAY_SIGN: "may sign if the deal is right"
# SIGN_UNDECIDED: "undecided"
# SIGN_PROBABLY_WONT: "probably won't sign"
# SIGN_UNKNOWN: "unknown" / "wasn't scouted"
# SIGN_FALLBACK: any other unrecognized signability text
SIGN_WILL_SIGN=1.0
SIGN_FIRST_ROUND=0.90
SIGN_FIRST_ROUND_THRESHOLD=70
SIGN_FIRST_FIVE=0.80
SIGN_FIRST_FIVE_THRESHOLD=60
SIGN_MAY_SIGN=0.60
SIGN_UNDECIDED=0.40
SIGN_PROBABLY_WONT=0.05
SIGN_UNKNOWN=0.0
SIGN_FALLBACK=0.50
